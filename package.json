{
  "name": "lanterm",
  "version": "0.7.10",
  "description": "LanTerm — a macOS terminal emulator",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node -e \"const f='package.json',p=JSON.parse(require('fs').readFileSync(f));const v=p.version.split('.');v[2]=+v[2]+1;p.version=v.join('.');require('fs').writeFileSync(f,JSON.stringify(p,null,2)+'\\n')\" && electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w node-pty",
    "mac": "npm run build && electron-builder --mac",
    "test": "npx playwright test && vitest run",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:smoke": "npx playwright test e2e/tests/smoke.spec.ts",
    "test:plugins": "npx playwright test src/plugins"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "uuid": "^11.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rollup-plugin-obfuscator": "^1.1.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
